--- a/xbmc/cores/VideoPlayer/VideoPlayer.h	2026-06-01 10:25:06.000000000 +0000
+++ b/xbmc/cores/VideoPlayer/VideoPlayer.h	2026-06-01 14:24:25.565251917 +0000
@@ -637,6 +637,7 @@ protected:
   bool m_realtimePostTransitionVideoDropLogged{false};
   bool m_realtimeStartupBufferingAllowed{true};
   bool m_realtimeExpectVideoStream{false};
+  bool m_realtimeForceVideoCodecReopen{false};
   std::chrono::steady_clock::time_point m_realtimeStartupAudioStallGraceUntil{};
   bool m_realtimeStartupAudioStallGraceLogged{false};
 
