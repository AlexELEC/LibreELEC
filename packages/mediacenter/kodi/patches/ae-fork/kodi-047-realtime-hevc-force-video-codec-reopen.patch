diff -Naurp a/xbmc/cores/VideoPlayer/VideoPlayer.cpp b/xbmc/cores/VideoPlayer/VideoPlayer.cpp
--- a/xbmc/cores/VideoPlayer/VideoPlayer.cpp	2026-06-01 10:25:06.000000000 +0000
+++ b/xbmc/cores/VideoPlayer/VideoPlayer.cpp	2026-06-01 14:24:25.564398099 +0000
@@ -1237,6 +1237,22 @@ bool CVideoPlayer::HandleStreamReset(boo
   const bool wasPending = m_realtimeStreamResetPending;
   const bool wasRealtimePlaybackStarted = realtime && m_State.streamsReady;
   const bool expectedRealtimeVideo = realtime && m_realtimeExpectVideoStream;
+
+  if (wasRealtimePlaybackStarted && expectedRealtimeVideo && m_CurrentVideo.id >= 0 &&
+      m_CurrentVideo.hint.codec == AV_CODEC_ID_HEVC)
+  {
+    // GENERAL_RESET is not enough for the HEVC decoder/output path after
+    // an in-place live STREAMRESET. If the stream id/hints look unchanged,
+    // OpenVideoStream() would otherwise keep the same video thread/codec alive
+    // and only send GENERAL_RESET, leaving a stuck renderer in
+    // OutputPicture/GetPicture timeouts. Force a real video player reopen, but
+    // keep the inputstream/socket and demuxer session alive.
+    m_realtimeForceVideoCodecReopen = true;
+  }
+
+  if (!wasRealtimePlaybackStarted)
+    m_realtimeForceVideoCodecReopen = false;
+
   m_realtimeStreamResetLastTry = now;
   m_realtimeQueuesFullSleepSince = {};
   m_realtimeQueuesFullLastSoftRecovery = {};
@@ -1377,6 +1393,15 @@ bool CVideoPlayer::HandleStreamReset(boo
               "VideoPlayer: realtime stream reset will restart A/V sync as fresh playback");
   }
 
+  if (expectedRealtimeVideo && m_realtimeForceVideoCodecReopen && m_CurrentVideo.id >= 0)
+  {
+    CLog::Log(LOGWARNING,
+              "VideoPlayer: realtime HEVC stream reset will reopen video codec/player without closing input socket");
+    CloseStream(m_CurrentVideo, false);
+    m_processInfo->ResetVideoCodecInfo();
+    m_HasVideo = false;
+  }
+
   if (expectedRealtimeVideo && m_CurrentAudio.id >= 0)
   {
     // The new video stream must be opened before audio is committed. Until then,
@@ -1419,6 +1444,7 @@ bool CVideoPlayer::HandleStreamReset(boo
   }
 
   m_realtimeStreamResetPending = false;
+  m_realtimeForceVideoCodecReopen = false;
   m_realtimeStreamResetLastTry = {};
   m_realtimeStreamResetPendingSince = {};
   m_realtimeFailedStreamChangeLogged = false;
