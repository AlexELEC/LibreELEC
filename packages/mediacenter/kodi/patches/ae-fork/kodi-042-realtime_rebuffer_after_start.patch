@@ -2261,18 +2308,38 @@ void CVideoPlayer::HandlePlaySpeed()
         // drift at -50ms/s and persistent A/V sync oscillation.
         if (m_CurrentAudio.id >= 0 && !IsPassthrough() && m_clock.GetClock() > DVD_MSEC_TO_TIME(1000))
