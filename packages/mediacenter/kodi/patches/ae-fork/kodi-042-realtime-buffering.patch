+bool CVideoPlayer::HandleStreamReset(bool resetDemuxer, bool retryPending)
+{
+  const bool realtime = m_pInputStream && m_pInputStream->IsRealtime();
+  constexpr auto pendingResetRetryInterval = 250ms;
+  const auto now = std::chrono::steady_clock::now();
+
+  if (retryPending && !resetDemuxer && m_realtimeStreamResetPending &&
+      m_realtimeStreamResetLastTry != std::chrono::steady_clock::time_point{} &&
+      now - m_realtimeStreamResetLastTry < pendingResetRetryInterval)
+  {
+    return false;
+  }
+
+  const bool wasPending = m_realtimeStreamResetPending;
+  const bool wasRealtimePlaybackStarted = realtime && m_State.streamsReady;
+  m_realtimeStreamResetLastTry = now;
+
+  auto markPending = [&](bool restartTimer)
+  {
+    if (!m_realtimeStreamResetPending ||
+        m_realtimeStreamResetPendingSince == std::chrono::steady_clock::time_point{} ||
+        restartTimer)
+      m_realtimeStreamResetPendingSince = now;
+
+    m_realtimeStreamResetPending = true;
+    m_realtimeBufferReadySince = {};
+    SetCaching(CACHESTATE_FULL);
+  };
+
+  if (!m_pDemuxer)
+  {
+    if (realtime && !m_bAbortRequest && !m_pendingOpenFile)
+    {
+      if (!wasPending)
+        CLog::Log(LOGWARNING,
+                  "VideoPlayer: [STREAM RESET] pending... Demuxer is not available");
+
+      // STREAMRESET is a one-shot marker. If it arrives while the demuxer is
+      // temporarily unavailable, remember it and complete it after the demuxer
+      // is recreated or the stream map is updated.
+      markPending(resetDemuxer);
+    }
+    return false;
+  }
+
+  if (resetDemuxer)
+  {
+    m_pDemuxer->Abort();
+    m_pDemuxer->Reset();
+    m_pDemuxer->Flush();
+  }
+
+  m_SelectionStreams.Clear(StreamType::NONE, STREAM_SOURCE_DEMUX);
+  m_SelectionStreams.Update(m_pInputStream, m_pDemuxer.get());
+  m_pDemuxer->GetPrograms(m_programs);
+  UpdateContent();
+
+  const int videoStreams = m_SelectionStreams.CountType(StreamType::VIDEO);
+  const int audioStreams = m_SelectionStreams.CountType(StreamType::AUDIO);
+
+  if (videoStreams == 0 && audioStreams == 0)
+  {
+    if (!wasPending)
+    {
+      CLog::Log(LOGWARNING,
+                "VideoPlayer: [STREAM RESET] pending... No demux A/V streams available after update");
+    }
+
+    // Do not close the currently opened players until there is something usable
+    // to open instead. STREAMRESET will not be sent again, so keep a pending
+    // reset and retry after stream-map changes or later demux packets.
+    markPending(resetDemuxer);
+    return false;
+  }
+
+  CloseStream(m_CurrentVideo, false);
+  m_processInfo->ResetVideoCodecInfo();
+
+  CloseStream(m_CurrentAudio, false);
+  m_processInfo->ResetAudioCodecInfo();
+
+  // Closing the old stream players can leave PLAYER_STARTED messages in the
+  // VideoPlayer queue. Do not let stale timestamps from the old timeline drive
+  // the next A/V sync after a realtime stream reset.
+  // Purge any pending PLAYER_STARTED messages.
+  m_messenger.Flush(CDVDMsg::PLAYER_STARTED);
+
+  if (wasRealtimePlaybackStarted)
+  {
+    // Treat an in-place realtime STREAMRESET like a fresh A/V startup. Keeping
+    // streamsReady=true across a TVLINK source switch lets the realtime-underrun
+    // watchdog see the very first packets of the new stream as normal playback.
+    // With sources such as real stream -> Empty channel this can immediately
+    // enter CACHESTATE_FULL at A/V levels like 100/1: audio already filled,
+    // video still starting. A normal channel startup does not do that because
+    // streamsReady is false until the new players report PLAYER_STARTED and are
+    // synced. Reset the lightweight playback-start state here without recreating
+    // the inputstream/demuxer, so the new audio/video timeline follows the same
+    // startup path as a clean open.
+    m_State.streamsReady = false;
+    m_State.dts = DVD_NOPTS_VALUE;
+    m_State.timestamp = 0.0;
+    m_State.time_offset = 0.0;
+
+    m_SpeedState.Reset(DVD_NOPTS_VALUE);
+    m_offset_pts = 0.0;
+    m_realtimeBufferReadySince = {};
+    m_realtimeBufferMaxHoldLogged = false;
+    m_realtimeAudioStallHoldLogged = false;
+    m_realtimeVideoStallHoldLogged = false;
+    m_realtimePostTransitionVideoGraceUntil = {};
+    m_realtimePostTransitionVideoDropSince = {};
+    m_realtimePostTransitionVideoDropLogged = false;
+
+    CLog::Log(LOGINFO,
+              "VideoPlayer: realtime stream reset will restart A/V sync as fresh playback");
+  }
+
+  OpenDefaultStreams(true);
+
+  m_HasVideo = (m_CurrentVideo.id >= 0);
+  m_HasAudio = (m_CurrentAudio.id >= 0);
+
+  if (!m_HasVideo && !m_HasAudio)
+  {
+    if (!wasPending)
+    {
+      CLog::Log(LOGWARNING,
+                "VideoPlayer: [STREAM RESET] pending... Failed to open default A/V streams. Demux A/V streams: {}/{}",
+                audioStreams, videoStreams);
+    }
+
+    markPending(resetDemuxer);
+    return false;
+  }
+
+  m_realtimeStreamResetPending = false;
+  m_realtimeStreamResetLastTry = {};
+  m_realtimeStreamResetPendingSince = {};
+  m_realtimeFailedStreamChangeLogged = false;
+  m_realtimeAudioStallHoldLogged = false;
+  m_realtimeVideoStallHoldLogged = false;
+  m_realtimePostTransitionVideoGraceUntil = {};
+  m_realtimePostTransitionVideoDropSince = {};
+  m_realtimePostTransitionVideoDropLogged = false;
+
+  // Keep the aggressive post-transition read window only for in-place realtime
+  // stream switches after playback has already started. The forced STREAMRESET
+  // used while opening a new inputstream is part of normal channel startup;
+  // arming the window there keeps demux reads active while A/V queues are full
+  // and can delay the next channel switch by several seconds. Use the saved
+  // pre-reset state because in-place resets intentionally clear streamsReady
+  // above to make the new A/V timeline start like a fresh open.
+  if (wasRealtimePlaybackStarted)
+  {
+    m_realtimeStreamTransitionReadUntil = now + 20s;
+    m_realtimeStreamTransitionReadLogged = false;
+    CLog::Log(LOGINFO,
+              "VideoPlayer: realtime transition read window armed after [STREAM RESET] (20s guard)");
+  }
+  else
+  {
+    m_realtimeStreamTransitionReadUntil = {};
+    m_realtimeStreamTransitionReadLogged = false;
+    m_realtimePostTransitionVideoGraceUntil = {};
+    m_realtimePostTransitionVideoDropSince = {};
+    m_realtimePostTransitionVideoDropLogged = false;
+  }
+
+  bad_packet_count = 0;
+  CLog::Log(LOGINFO,
+            "VideoPlayer: [STREAM RESET] done! Demux A/V streams: {}/{} | Current A/V IDs: {}/{}",
+            audioStreams, videoStreams, m_CurrentAudio.id, m_CurrentVideo.id);
+  return true;
+}
